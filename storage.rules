rules_version = '2';

// I-R-E-S Storage security rules.
// Files are keyed by their content hash under /images/{hash}.
service firebase.storage {
  match /b/{bucket}/o {
    match /images/{hash} {
      // Download links are public so recipients can view a verified document.
      allow read: if true;

      // Only signed-in users may upload, and files are capped at 15 MB.
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024;
    }
  }
}
